# ── Database (PostgreSQL / Neon) ──
DB_HOST=localhost
DB_PORT=5433
DB_NAME=bankdb
DB_USERNAME=bankuser
DB_PASSWORD=bankpass

# ── JWT ──
JWT_SECRET=your-base64-encoded-secret-here
JWT_EXPIRATION=86400000

# ── Mail (Gmail example) ──
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM=noreply@javabank.com

# ── LLM Provider: "ollama" (local) or "groq" (cloud free) ──
LLM_PROVIDER=ollama
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama3-70b-8192

# ── Ollama (local dev only) ──
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# ── Spring Boot ──
SPRING_PROFILES_ACTIVE=local
BANKING_CORE_URL=http://localhost:8081/api/v1
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000

# ── React UI ──
VITE_API_URL=http://localhost:8000

# ── Redis (Upstash for production, localhost for dev) ──
REDIS_URL=
REDIS_HOST=localhost
REDIS_PORT=6379
